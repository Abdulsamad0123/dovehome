# Formspree Configuration for Contact Form
# 
# To set up the contact form email functionality:
# 1. Go to https://formspree.io and create a free account
# 2. Create a new form and set the recipient email to: dovehomes247@gmail.com
# 3. Copy the form endpoint URL (it will look like: https://formspree.io/f/xxxxx)
# 4. Paste it below or set it in your Vercel environment variables
#
# Format examples:
# - Direct email: https://formspree.io/dovehomes247@gmail.com
# - Form ID: https://formspree.io/f/xxxxxxxxx
#
VITE_FORMSPREE_ENDPOINT=https://formspree.io/dovehomes247@gmail.com
